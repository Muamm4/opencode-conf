{
  "$schema": "https://raw.githubusercontent.com/cortexkit/opencode-magic-context/master/schema.json",
  "magic_context": {
    "enabled": true,
    "models": {
      "historian": "opencode/minimax-m2.5-free",
      "dreamer": "opencode/minimax-m2.5-free",
      "sidekick": "opencode/minimax-m2.5-free"
    },
    "memory": {
      "enabled": true,
      "maxMemories": 200,
      "importanceThreshold": 0.6
    },
    "context": {
      "maxTokens": 8000,
      "injectionBudget": 2000,
      "recentMessages": 15
    },
    "compression": {
      "enabled": true,
      "chunkSize": 2000,
      "aggressive": true
    },
    "retrieval": {
      "maxResults": 8,
      "rerank": true
    },
    "background": {
      "historianInterval": 2,
      "dreamerInterval": 10
    }
  }
}